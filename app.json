{
  "expo": {
    "name": "Phoenix Neumed's Pallanguzhi",
    "slug": "phoenix-neumed-pallanguzhi",
    "scheme": "pallanguzhi",
    "version": "1.0.0",
    "runtimeVersion": { "policy": "appVersion" },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#FBF4E6",
    "primaryColor": "#D4A32C",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF4E6"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phoenixneumed.pallanguzhi",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.phoenixneumed.pallanguzhi",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF4E6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Phoenix Neumed's Pallanguzhi",
      "backgroundColor": "#FBF4E6",
      "themeColor": "#D4A32C"
    },
    "plugins": [
      "expo-localization",
      "expo-font",
      "expo-audio",
      "expo-asset"
    ]
  }
}
