# --- Phoenix Neumed's Pallanguzhi (Expo app) ---
# URL of the multiplayer server (see ./server). Inlined at build time because
# it is prefixed with EXPO_PUBLIC_. Use wss:// in production.
#
#   Render (production):   wss://your-service.onrender.com
#   Web / iOS simulator:   ws://localhost:8080
#   Physical device (LAN): ws://192.168.x.x:8080   (your computer's LAN IP)
#
# http(s) values are auto-normalized to ws(s) by src/features/multiplayer/config.ts.
EXPO_PUBLIC_SERVER_URL=ws://localhost:8080
